{
    "manifest_version": 3,
    "name": "BMET Toolkit",
    "version": "4.0",
    "description": "BMET Toolkit: PM logs, inventory, calibration alerts, and dashboard.",
    "permissions": ["storage", "notifications", "alarms"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "BMET Toolkit"
    },
    "options_page": "options.html",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}